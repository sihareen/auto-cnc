# Production environment variables
CNC_PORT=/dev/ttyUSB0
CNC_BAUDRATE=115200
CNC_TIMEOUT=2

CAMERA_INDEX=0
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080

YOLO_MODEL_PATH=models/best.pt
YOLO_CONFIDENCE_THRESHOLD=0.5

AFFINE_MATRIX_PATH=config/calibration_affine.json

DRILL_DEPTH=-1.5
DRILL_FEEDRATE=300
RAPID_FEEDRATE=1000
CLEARANCE_HEIGHT=5

HOST=0.0.0.0
PORT=8000

LOG_LEVEL=INFO
LOG_PATH=logs/auto_cnc.log
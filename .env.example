# CNC Configuration
CNC_PORT=/dev/ttyUSB0
CNC_BAUDRATE=115200
CNC_RETRY_TIMEOUT=3
CNC_RETRY_ATTEMPTS=3

# Camera Configuration (USB Camera 0ac8:3370)
# Auto-detected: video4 (fallback: 0, 2)
CAMERA_INDEX=4
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# YOLO Configuration
YOLO_MODEL_PATH=models/best.pt
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_IOU_THRESHOLD=0.5

# Affine Transformation
AFFINE_MATRIX_PATH=config/calibration_affine.json

# Job Settings
DRILL_DEPTH=-1.5
DRILL_FEEDRATE=300
RAPID_MOVE_FEEDRATE=1000
CLEARANCE_HEIGHT=5

# Web Server
HOST=0.0.0.0
PORT=8000
WEB_SOCKET_PORT=8001

# Logging
LOG_LEVEL=INFO
LOG_PATH=logs/auto_cnc.log